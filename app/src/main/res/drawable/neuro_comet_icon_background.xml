<?xml version="1.0" encoding="utf-8"?>
<!-- Default NeuroComet - Purple/blue gradient matching brand -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#667eea"
                android:centerColor="#6E70DC"
                android:endColor="#764ba2" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:centerX="0.30"
                android:centerY="0.22"
                android:gradientRadius="88dp"
                android:startColor="#40FFFFFF"
                android:centerColor="#14FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:centerX="0.78"
                android:centerY="0.82"
                android:gradientRadius="120dp"
                android:startColor="#240E1220"
                android:endColor="#000E1220" />
        </shape>
    </item>

    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <stroke
                android:width="1dp"
                android:color="#22FFFFFF" />
        </shape>
    </item>
</layer-list>
