<?xml version="1.0" encoding="utf-8"?>
<!-- Energy Burst - Vibrant pink/purple gradient for motivation -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#f093fb"
                android:centerColor="#F77FA8"
                android:endColor="#f5576c" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:centerX="0.28"
                android:centerY="0.18"
                android:gradientRadius="92dp"
                android:startColor="#42FFFFFF"
                android:centerColor="#14FFF1F7"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:centerX="0.80"
                android:centerY="0.82"
                android:gradientRadius="124dp"
                android:startColor="#280F0912"
                android:endColor="#000F0912" />
        </shape>
    </item>

    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <stroke
                android:width="1dp"
                android:color="#24FFFFFF" />
        </shape>
    </item>
</layer-list>
