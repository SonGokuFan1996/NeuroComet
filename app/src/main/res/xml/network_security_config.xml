<?xml version="1.0" encoding="utf-8"?>
<!--
   Network Security Configuration for NeuroComet.

   Security rules:
   1. Cleartext (HTTP) traffic is BLOCKED globally.
      All communication must use HTTPS.
   2. Debug builds allow a user-installed CA for proxy tools like Charles/mitmproxy.
   3. Certificate pinning for critical domains can be added below.

   See https://developer.android.com/training/articles/security-config
-->
<network-security-config>

    <!-- Block all cleartext (HTTP) traffic by default -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Debug overrides: allow user-installed CAs for proxy debugging -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>

</network-security-config>

