<?xml version="1.0" encoding="utf-8"?>
<!--
   Backup rules for NeuroComet.
   Exclude secure credential storage from cloud backup to prevent auth token leakage.
   See https://developer.android.com/about/versions/12/backup-restore
-->
<full-backup-content>
    <exclude domain="sharedpref" path="neurocomet_secure_prefs.xml" />
    <exclude domain="sharedpref" path="neurocomet_credential_store.xml" />
</full-backup-content>